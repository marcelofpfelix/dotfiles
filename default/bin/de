#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# custom docker exec with shell selection
################################################################################

# change to local directory
cd "$(dirname "$0")" || exit
# load libs
. ../lib/lib_utils.sh

exec() {
  sudo docker exec -it "$container" env PS1='\['"$BBlue"'\]'$(hostname -s)'@\['"$BPurple"'\]'"$container"'\['"$BBlue"'\]:\w \['"$BPurple"'\]\$\['"$nocolor"'\] ' env "$1"
}

de() {
  [ -z "$1" ] && dps && return 1
  container=$1
  shift

  if [ "$#" -eq 0 ]; then
    for shell in bash ash sh dash; do
      exec "$shell"
      result=$?
      [ "$result" -ne 127 ] && break
    done

    [ "$result" -eq 127 ] && echo "Shell not available: $container"
    [ "$result" -eq 1 ] && dps
  else
    sudo docker exec "$container" "$@"
    return $?
  fi
}

de "$@"
