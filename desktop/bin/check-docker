#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# check docker containers status
################################################################################

set -Eeuo pipefail

  # change to local directory
cd "$(dirname "$0")" || exit

DOCKER_EXPECTED=${DOCKER_EXPECTED:-0}

show_status() {
  DOCKER_RUNNING=$(docker ps -q 2>/dev/null | wc -l | tr -d ' \t')
  DOCKER_STOPPED=$(docker ps -q --filter "status=exited" 2>/dev/null | wc -l | tr -d ' \t')

  if (( DOCKER_STOPPED > 0 )); then
    printc "$(icon docker)" r
  elif (( DOCKER_EXPECTED > 0 && DOCKER_RUNNING != DOCKER_EXPECTED )); then
    printc "$(icon docker)" y
  else
    printc "$(icon docker)" g
  fi
  printc "${DOCKER_RUNNING}" n
  if (( DOCKER_STOPPED > 0 )); then
    printc "/${DOCKER_STOPPED}" r
  fi
  printf "\n"

  if (( DOCKER_STOPPED > 0 )); then
    return 2
  elif (( DOCKER_EXPECTED > 0 && DOCKER_RUNNING != DOCKER_EXPECTED )); then
    return 1
  fi
}

main() {
  LIBS_DIR=${LIBS_DIR:="$HOME/lib"}
  . "$LIBS_DIR/lib_utils.sh"
  . "$LIBS_DIR/lib_icon.sh"
  . "$LIBS_DIR/lib_status.sh"

  if show_status; then
    code=0
  else
    code=$?
  fi
  report_check_status \
    "check-docker" "$code" "running=${DOCKER_RUNNING:-0} stopped=${DOCKER_STOPPED:-0}" \
    "$(prometheus_check_metric "check-docker" "docker_running_containers" "${DOCKER_RUNNING:-0}")" \
    "$(prometheus_check_metric "check-docker" "docker_stopped_containers" "${DOCKER_STOPPED:-0}")" \
    "$(prometheus_check_metric "check-docker" "docker_expected_containers" "$DOCKER_EXPECTED")"
  exit "$code"
}

main "$@"
