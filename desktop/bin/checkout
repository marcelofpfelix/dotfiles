#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# git checkout a new branch
################################################################################

set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/lib_git.sh" ]; then
    LIBS_DIR="${LIBS_DIR:-$SCRIPT_DIR/../lib}"
elif [ -f "$SCRIPT_DIR/../../default/lib/lib_git.sh" ]; then
    LIBS_DIR="${LIBS_DIR:-$SCRIPT_DIR/../../default/lib}"
else
    LIBS_DIR="${LIBS_DIR:-$HOME/lib}"
fi
. "$LIBS_DIR/lib_git.sh"

main() {
    if [ "$#" -ne 1 ]; then
        echo "Usage: checkout <branch>" >&2
        exit 2
    fi

    git_checkout_feature_branch "$1"
}

main "$@"
