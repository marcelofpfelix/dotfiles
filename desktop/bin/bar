#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# bar to show in polybar
################################################################################

export LEMONBAR=1

# scripts to run (collected into a single space-separated line)
SCRIPTS=(check-docker check-temp)
#SCRIPTS+=(alerts check-time check-resolv check-safe)

OUTPUTS=()
for script in "${SCRIPTS[@]}"; do
  out=$("$script" 2>&1 | tr -d '\n')
  [[ -n "$out" ]] && OUTPUTS+=("$out")
done

echo "${OUTPUTS[*]}"
