#!/usr/bin/env python3

"""
Normalize agent lifecycle hook events for agent-tmux.
"""

from __future__ import annotations

import json
import hashlib
import os
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path


DEFAULT_BLOCKED_RE = (
    r"(permission|approval|approve|allow|confirm|choose an option|"
    r"do you want to|yes/no|\by/n\b)"
)
DEFAULT_NOTIFY_STATES = "blocked"


def state_dir() -> Path:
    root = os.environ.get("AGENT_TMUX_STATE_DIR")
    if root:
        return Path(root)
    return Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "agent-tmux"


def redact(value: str) -> str:
    value = re.sub(r"(Authorization: Bearer )[A-Za-z0-9._~+/=-]+", r"\1[REDACTED]", value)
    value = re.sub(r"(Bearer )[A-Za-z0-9._~+/=-]+", r"\1[REDACTED]", value)
    value = re.sub(r"(IKEY_)[A-Za-z0-9._~-]+", r"\1[REDACTED]", value)
    return value


def safe_text(payload: object, raw: str) -> str:
    if isinstance(payload, dict):
        for key in ("message", "reason", "notification", "summary", "tool_name", "subtype"):
            value = payload.get(key)
            if isinstance(value, str) and value.strip():
                return redact(value.strip().replace("\n", " ").replace("\t", " "))[:240]
        return ""
    if raw and len(raw) < 500 and not re.search(r'"prompt"|"user_prompt"|"input"', raw, re.I):
        return redact(raw.strip().replace("\n", " ").replace("\t", " "))[:240]
    return ""


def cwd_from_payload(payload: object) -> str:
    if isinstance(payload, dict):
        for key in ("cwd", "current_working_directory", "workspace_root", "project_root"):
            value = payload.get(key)
            if isinstance(value, str) and value:
                return str(Path(value).expanduser().resolve())
    return str(Path(os.environ.get("AGENT_TMUX_EVENT_CWD", os.getcwd())).expanduser().resolve())


def repo_root_from_cwd(cwd: str) -> str:
    current = Path(cwd)
    for path in [current, *current.parents]:
        if (path / ".git").exists():
            return str(path)
    return ""


def session_from_payload(payload: object) -> str:
    if isinstance(payload, dict):
        for key in ("session_id", "conversation_id", "transcript_path", "thread_id"):
            value = payload.get(key)
            if isinstance(value, str) and value:
                return value
    return os.environ.get("AGENT_TMUX_EVENT_SESSION", "")


def state_for_event(event: str, message: str, raw: str) -> str:
    normalized = event.lower()
    if normalized in {"permissionrequest", "permission_request"}:
        return "blocked"
    if normalized in {"stop", "sessionend", "session_end"}:
        return "free"
    if normalized in {
        "userpromptsubmit",
        "user_prompt_submit",
        "pretooluse",
        "pre_tool_use",
        "posttooluse",
        "post_tool_use",
        "subagentstart",
        "subagent_start",
    }:
        return "running"
    if normalized in {"notification", "notify"}:
        blocked_re = os.environ.get("AGENT_TMUX_EVENT_BLOCKED_RE", DEFAULT_BLOCKED_RE)
        return "blocked" if re.search(blocked_re, f"{message}\n{raw}", re.I) else "free"
    return os.environ.get("AGENT_TMUX_EVENT_DEFAULT_STATE", "running")


def load_state(path: Path) -> list[list[str]]:
    if not path.exists():
        return []
    rows: list[list[str]] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        fields = line.split("\t")
        if len(fields) >= 8:
            if len(fields) < 9:
                fields.append("")
            rows.append(fields[:9])
    return rows


def write_atomic(path: Path, content: str) -> None:
    tmp = path.with_name(f"{path.name}.{os.getpid()}.tmp")
    tmp.write_text(content, encoding="utf-8")
    tmp.replace(path)


def enabled(value: str | None, default: bool = True) -> bool:
    if value is None:
        return default
    return value.lower() not in {"0", "false", "no", "off"}


def state_notify_enabled(state: str) -> bool:
    states = os.environ.get("AGENT_TMUX_NOTIFY_STATES", DEFAULT_NOTIFY_STATES)
    return state in {item.strip() for item in states.split(",") if item.strip()}


def notify_cooldown_ok(directory: Path, key: str, state: str, now: int) -> bool:
    cooldown = int(os.environ.get("AGENT_TMUX_NOTIFY_COOLDOWN", "300"))
    stamp = directory / f"event-notify-{key}-{state}.stamp"
    try:
        last = int(stamp.read_text(encoding="utf-8").strip()) if stamp.exists() else 0
    except ValueError:
        last = 0
    if now - last < cooldown:
        return False
    stamp.write_text(f"{now}\n", encoding="utf-8")
    return True


def run_notifier(command: list[str], message: str) -> bool:
    try:
        subprocess.run(command, input=message, text=True, timeout=2, check=False)
    except (OSError, subprocess.TimeoutExpired):
        return False
    return True


def send_notification(message: str) -> None:
    notifier = os.environ.get("AGENT_TMUX_NOTIFY", "auto")
    if notifier == "auto":
        if shutil.which("notify-send") and run_notifier(["notify-send", "tmux agent", message], ""):
            return
        if shutil.which("terminal-notifier") and run_notifier(["terminal-notifier", "-title", "tmux agent", "-message", message], ""):
            return
        if shutil.which("telemsg") and run_notifier(["telemsg", message], ""):
            return
        return

    if shutil.which(notifier):
        run_notifier([notifier, message], "")


def maybe_notify_event(
    directory: Path,
    agent: str,
    cwd: str,
    repo_root: str,
    state: str,
    event: str,
    duration: str,
    message: str,
    now: int,
    previous: list[str] | None,
) -> None:
    if not enabled(os.environ.get("AGENT_TMUX_EVENT_NOTIFY"), True):
        return
    if previous and previous[2] == state:
        return
    if not state_notify_enabled(state):
        return

    key = hashlib.sha256(f"{agent}|{cwd}".encode("utf-8")).hexdigest()[:16]
    if not notify_cooldown_ok(directory, key, state, now):
        return

    location = Path(repo_root or cwd).name
    suffix = ""
    if duration.isdigit() and int(duration) > 0:
        seconds = int(duration)
        if seconds < 60:
            suffix = f" for {seconds}s"
        elif seconds < 3600:
            suffix = f" for {seconds // 60}m"
        else:
            suffix = f" for {seconds // 3600}h"
    detail = f": {message}" if message else ""
    send_notification(f"[{agent}] {state}{suffix} in {location} ({event}){detail}")


def main() -> int:
    if len(sys.argv) < 3:
        print("usage: agent-event AGENT EVENT", file=sys.stderr)
        return 2

    agent = sys.argv[1].lower()
    if agent == "claudecode":
        agent = "claude"
    event = sys.argv[2]
    raw = sys.stdin.read()
    try:
        payload: object = json.loads(raw) if raw.strip() else {}
    except json.JSONDecodeError:
        payload = {}

    now = int(time.time())
    cwd = cwd_from_payload(payload)
    repo_root = repo_root_from_cwd(cwd)
    session = session_from_payload(payload)
    message = safe_text(payload, raw)
    state = state_for_event(event, message, raw)

    directory = state_dir()
    directory.mkdir(parents=True, exist_ok=True)
    state_path = directory / "event-state.tsv"
    log_path = directory / "events.jsonl"

    rows = load_state(state_path)
    previous = next((row for row in rows if row[0] == agent and row[1] == cwd), None)
    started = str(now)
    if previous and previous[2] == "running":
        started = previous[5] or previous[4]
    if state == "running" and previous and previous[2] == "running":
        started = previous[5] or previous[4]

    duration = "0"
    if state in {"free", "blocked"} and started.isdigit():
        duration = str(max(0, now - int(started)))

    rows = [row for row in rows if not (row[0] == agent and row[1] == cwd)]
    rows.append([agent, cwd, state, event, str(now), started, duration, message, repo_root])
    write_atomic(state_path, "\n".join("\t".join(row) for row in rows) + "\n")
    maybe_notify_event(directory, agent, cwd, repo_root, state, event, duration, message, now, previous)

    log_record = {
        "agent": agent,
        "event": event,
        "state": state,
        "cwd": cwd,
        "repo_root": repo_root,
        "session": session,
        "updated_at": now,
        "started_at": int(started) if started.isdigit() else now,
        "duration": int(duration),
        "message": message,
    }
    with log_path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(log_record, sort_keys=True) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
