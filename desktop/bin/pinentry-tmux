#!/bin/bash

# Custom pinentry wrapper that redirects prompts to a dedicated tmux pane.
# Falls back to the current TTY if the pinentry pane is not available.
#
# Configure in ~/.gnupg/gpg-agent.conf:
#   pinentry-program /path/to/pinentry-tmux

TTY_FILE="$HOME/.pinentry_tty"

if [[ -f "$TTY_FILE" ]]; then
    PINENTRY_TTY=$(cat "$TTY_FILE")
    # verify the TTY still exists
    if [[ -e "$PINENTRY_TTY" ]]; then
        exec pinentry-tty --ttyname "$PINENTRY_TTY" "$@"
    fi
fi

# fallback to default pinentry-tty on current terminal
exec pinentry-tty "$@"
