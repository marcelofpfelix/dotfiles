#!/bin/bash

# Custom pinentry wrapper that redirects prompts to a dedicated tmux pane.
# Falls back to pinentry-gnome3 (GUI dialog) if the pane is not available.
#
# Configure in ~/.gnupg/gpg-agent.conf:
#   pinentry-program /home/marcelof/bin/pinentry-tmux
#
# To set up the dedicated tmux pane:
#   pinentry-tmux-setup [session]

TTY_FILE="$HOME/.pinentry_tty"

if [[ -f "$TTY_FILE" ]]; then
    PINENTRY_TTY=$(cat "$TTY_FILE")
    if [[ -e "$PINENTRY_TTY" ]]; then
        exec pinentry-tty --ttyname "$PINENTRY_TTY" "$@"
    fi
fi

# fallback: open a GUI dialog instead of hoping for a valid TTY
exec pinentry-gnome3 "$@"
