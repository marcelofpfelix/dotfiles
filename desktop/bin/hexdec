#!/usr/bin/env python3
"""Convert between colon-separated hex and decimal."""

import sys

def main():
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <hex_or_decimal>")
        print("  hex→dec: hexdec 05:c9:5b:60:af:3e:b7:69")
        print("  dec→hex: hexdec 504079647172415301")
        sys.exit(1)

    s = sys.argv[1]

    if ":" in s:
        print(int(s.replace(":", ""), 16))
    else:
        h = format(int(s), "x")
        if len(h) % 2:
            h = "0" + h
        print(":".join(h[i:i+2] for i in range(0, len(h), 2)))

if __name__ == "__main__":
    main()
