################################################################################
#                                 FILE INFO
# cli with boa
CLI="""
use: gwt
short: manage git worktrees
long: |
  manage git worktrees
commands:
  - use: clone
    short: repo to clone
    aliases:
      - c
    flags:
      - use: repo
        short: repository
        alias: r
        type: string
  - use: switch
    short: switch to a specific worktree
    aliases:
      - s
    flags:
      - use: repo
        short: repository
        alias: r
        type: string
      - use: main
        short: switch to main branch
        alias: m
        type: bool
      - use: work
        short: search in work user
        alias: w
        type: bool
  - use: add
    short: add a specific worktree
    aliases:
      - a
    flags:
      - use: name
        short: branch name
        alias: n
        type: string
"""
################################################################################

# should exit as soon as it encounters any non-zero exit code or usage of
# undefined variables or failed piped commands
set -Ee -o pipefail

LOCAL_DIR="$PWD"
RAW_ARGS=("$@")
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/lib_utils.sh" ]; then
    LIBS_DIR="${LIBS_DIR:-$SCRIPT_DIR/../lib}"
elif [ -f "$SCRIPT_DIR/../../default/lib/lib_utils.sh" ]; then
    LIBS_DIR="${LIBS_DIR:-$SCRIPT_DIR/../../default/lib}"
else
    LIBS_DIR="${LIBS_DIR:-$HOME/lib}"
fi
cd "$SCRIPT_DIR" || exit 1
. "$LIBS_DIR/lib_utils.sh"
# global variables
LOG_LEVEL=3 # default is 1:NOTE
git_dir="${GWT_REPOS_ROOT:-$HOME/gwt}"

USER=marcelofpfelix
WORK_REPO="team-telnyx"
REPO_IGNORE='-not -path "./$WORK_REPO*"'



gwt() {
    help
}

gwt_clone() {
    # no subcommands, running the function
    repo_url="${ARGS[1]}"
    # print the result
    log INFO "Running:" "${CMDS[@]}" "-r ${repo_url}" n:b:c:b:c

    if [ -z "$repo_url" ]; then
        repo_url=$(gum input --placeholder github.com/ --prompt "Enter the repo: " --value "")
    fi

    repo="$(git_repo_name_from_url "$repo_url")"
    user="$(git_repo_owner_from_url "$repo_url")"
    log INFO "user/repo: $user/$repo"

    repo_path="$git_dir/$user/$repo/main"
    git_repo_ensure "$user" "$repo" "$repo_path" "$(git_repo_url "$user" "$repo")" true default
    cd "$repo_path" || return
    default_branch="$(git_current_branch)"
    tmux new-window -n "${repo}_${default_branch}" -c "$repo_path"
}

gwt_add() {
    branch="${ARGS[1]:-${RAW_ARGS[1]:-}}"
    repo_base=""
    repo_context=""
    repo_root=""
    git_common_dir=""
    worktree_path=""
    if [[ -z "$branch" ]]; then
        log ERRO "Missing branch name. Usage: gwt add <branch> or gwt add -n <branch>"
        exit 2
    fi

    log DEBG "${LOCAL_DIR}/.bare/HEAD"

    cd "${LOCAL_DIR}"
    if [[ -d "${LOCAL_DIR}/.bare" ]]; then
        repo_base="${LOCAL_DIR}"
        repo_context="${LOCAL_DIR}/.bare"
    else
        repo_root="$(git rev-parse --show-toplevel)" || return
        git_common_dir="$(git -C "$repo_root" rev-parse --git-common-dir)" || return
        if [[ "$git_common_dir" != /* ]]; then
            git_common_dir="$repo_root/$git_common_dir"
        fi
        if [[ "$(basename "$git_common_dir")" = ".bare" ]]; then
            repo_base="$(dirname "$git_common_dir")"
            repo_context="$git_common_dir"
        else
            repo_base="$(dirname "$repo_root")"
            repo_context="$repo_root"
        fi
    fi
    worktree_path="$repo_base/$branch"

    git_repo_normalize_origin_url "$repo_context" || return
    git -C "$repo_context" fetch origin
    default_branch="$(git -C "$repo_context" symbolic-ref --short HEAD 2>/dev/null)"
    if [[ -z "$default_branch" ]]; then
        default_branch="$(git -C "$repo_context" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)"
        default_branch="${default_branch#refs/remotes/origin/}"
    fi
    if [[ -n "$default_branch" ]] && ! git -C "$repo_context" show-ref --verify --quiet "refs/remotes/origin/$default_branch"; then
        default_branch=""
    fi
    if [[ -z "$default_branch" ]] && git -C "$repo_context" show-ref --verify --quiet refs/remotes/origin/master; then
        default_branch="master"
    elif [[ -z "$default_branch" ]] && git -C "$repo_context" show-ref --verify --quiet refs/remotes/origin/main; then
        default_branch="main"
    fi
    default_branch="${default_branch:-main}"
    if git -C "$repo_context" show-ref --verify --quiet "refs/heads/${branch}"; then
        git -C "$repo_context" worktree add "$worktree_path" "$branch"
    elif git -C "$repo_context" show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
        git -C "$repo_context" worktree add -b "$branch" "$worktree_path" "origin/$branch"
    else
        git -C "$repo_context" worktree add -b "$branch" "$worktree_path" "origin/$default_branch"
    fi

    # add option for remote
    # git worktree add -b PROXY-1373 ./PROXY-1373 origin/PROXY-1373
}

gwt_switch() {

    # no subcommands, running the function
    repo_url="${ARGS[1]}"
    main="${ARGS[2]}"
    work="${ARGS[3]}"
    depth=3
    user=""
    ignore="$WORK_REPO"

    # print the result
    log INFO "Running:" "${CMDS[@]}" "-r ${repo_url}" "-m $main" "-w $work" n:b:c:b:c

    if [ "$main" = "true" ]; then
      depth=2
    fi
    if [ "$work" = "true" ]; then
      ignore=$USER
      user=$WORK_REPO
      depth=2
    fi
# -printf "%P"

    #echo       find ./ -mindepth $depth -maxdepth $depth -type d -not -path "*.bare" -not -path "archive" -not -path "./$ignore*" -prune - fzf -q "$repo_url"
#    if [ -z "$repo_url" ]; then
    cd $git_dir/$user
    repo_url=$(find ./ -mindepth $depth -maxdepth $depth -type d -not -path "*.bare" -not -path "archive" -not -path "./$ignore*" -prune  -printf "%P\n" | fzf -q "$repo_url")
    [[ -z "$repo_url" ]] && exit 1
#    fi

#Notes="""
#fzf --preview "bat --color=always --style=numbers --line-range=:500 {}"
#"""

    tmux new-window -n $repo_url -c $git_dir/$user/$repo_url
    cd $git_dir/$user/$repo_url
    git_repo_normalize_origin_url . || return
    branch=${PWD##*/}
    git fetch origin
    git pull origin $branch
}

    # commands
    # add
    # list
    # switch
# run the command selected
[[ -n "$CMD" ]] && "$CMD"

