#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# check cpu temperature (Linux only, requires lm-sensors)
################################################################################

set -Eeuo pipefail

  # change to local directory
cd "$(dirname "$0")" || exit

show_status() {
  local temp_raw

  temp_raw=$(sensors | grep temp1 | head -n1 | awk '{print $2}' | tr -d '+°C')
  TEMP_C=${temp_raw%.*}

  if (( TEMP_C >= 80 )); then
    printc "$(icon temp)" r
  elif (( TEMP_C >= 60 )); then
    printc "$(icon temp)" y
  else
    printc "$(icon temp)" g
  fi
  printf "%2d\n" "$TEMP_C"

  if (( TEMP_C >= 80 )); then
    return 2
  elif (( TEMP_C >= 60 )); then
    return 1
  fi
}

main() {
  LIBS_DIR=${LIBS_DIR:="$HOME/lib"}
  . "$LIBS_DIR/lib_utils.sh"
  . "$LIBS_DIR/lib_icon.sh"
  . "$LIBS_DIR/lib_status.sh"

  if show_status; then
    code=0
  else
    code=$?
  fi
  report_check_status \
    "check-temp" "$code" "temperature_celsius=${TEMP_C:-0}" \
    "$(prometheus_check_metric "check-temp" "temperature_celsius" "${TEMP_C:-0}")"
  exit "$code"
}

main "$@"
