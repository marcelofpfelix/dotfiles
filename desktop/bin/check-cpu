#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# check cpu usage percentage
################################################################################

set -Eeuo pipefail

  # change to local directory
cd "$(dirname "$0")" || exit

show_status() {
  case "$(uname)" in
    Linux)
      read -r _ u1 n1 s1 i1 _ < /proc/stat
      sleep 1
      read -r _ u2 n2 s2 i2 _ < /proc/stat
      local active=$(( (u2-u1) + (n2-n1) + (s2-s1) ))
      local total=$(( active + (i2-i1) ))
      CPU_PCT=$(( active * 100 / total ))
      ;;
    Darwin)
      CPU_PCT=$(top -l 2 -n 0 -s 1 2>/dev/null | awk '/^CPU usage/ {gsub(/%/,""); print int($3+$5)}' | tail -1)
      ;;
  esac

  if [ -z "${CPU_PCT:-}" ]; then
    CPU_PCT=0
    printc "$(icon cpu)" r
    printf "%2d\n" "$CPU_PCT"
    return 2
  fi

  if (( CPU_PCT >= 85 )); then
    printc "$(icon cpu)" r
  elif (( CPU_PCT >= 60 )); then
    printc "$(icon cpu)" y
  else
    printc "$(icon cpu)" g
  fi
  printf "%2d\n" "$CPU_PCT"

  if (( CPU_PCT >= 85 )); then
    return 2
  elif (( CPU_PCT >= 60 )); then
    return 1
  fi
}

main() {
  LIBS_DIR=${LIBS_DIR:="$HOME/lib"}
  . "$LIBS_DIR/lib_utils.sh"
  . "$LIBS_DIR/lib_icon.sh"
  . "$LIBS_DIR/lib_status.sh"

  if show_status; then
    code=0
  else
    code=$?
  fi
  report_check_status \
    "check-cpu" "$code" "usage_percent=${CPU_PCT:-0}" \
    "$(prometheus_check_metric "check-cpu" "cpu_usage_percent" "${CPU_PCT:-0}")"
  exit "$code"
}

main "$@"
