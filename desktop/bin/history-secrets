#!/usr/bin/env bash

################################################################################
#                                 FILE INFO
# Scan shell history (atuin, zsh, clipboard) for leaked secrets using gitleaks.
# Generates delete commands for review — nothing is deleted automatically.
#
# Clipboard backend controlled by CLIP_BACKEND env var (gpaste or copyq).
#
# Usage:
#   history-secrets [atuin|zsh|clipboard|all]   (default: all)
#   history-secrets --apply                     scan all and apply deletions
################################################################################

set -Eeuo pipefail

ZSH_HISTORY="${HISTFILE:-$HOME/.zsh_history}"
CLIP_BACKEND="${CLIP_BACKEND:-gpaste}"
GPASTE_HISTORY="$HOME/.local/share/gpaste/history.xml"
COPYQ_HISTORY="$HOME/.local/share/copyq/copyq-bak.dat"
REPORT=$(mktemp --suffix=.json)

trap 'shred --remove "$REPORT" 2>/dev/null || rm -f "$REPORT"' EXIT

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2
}

check_deps() {
    local missing=()
    for cmd in gitleaks jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        log "ERROR: missing dependencies: ${missing[*]}"
        exit 1
    fi
}

scan_atuin() {
    log "Scanning atuin history..."

    if ! command -v atuin &>/dev/null; then
        log "SKIP: atuin not installed"
        return
    fi

    atuin history list --cmd-only 2>/dev/null \
        | gitleaks detect --pipe -r "$REPORT" --no-banner 2>/dev/null || true

    if [[ ! -s "$REPORT" ]] || [[ "$(jq 'length' "$REPORT" 2>/dev/null)" == "0" ]]; then
        log "atuin: no secrets found"
        return
    fi

    local count
    count=$(jq 'length' "$REPORT")
    log "atuin: found $count secret(s)"

    if [[ "$APPLY" == true ]]; then
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            log "atuin: deleting entries matching secret"
            atuin search --delete "$secret" 2>/dev/null || true
        done
        log "atuin: cleanup applied"
    else
        echo ""
        echo "# --- atuin: review and run these commands ---"
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            echo "atuin search --delete '$secret'"
        done
    fi

    : > "$REPORT"
}

scan_zsh() {
    log "Scanning zsh history..."

    if [[ ! -f "$ZSH_HISTORY" ]]; then
        log "SKIP: zsh history not found at $ZSH_HISTORY"
        return
    fi

    gitleaks detect --pipe -r "$REPORT" --no-banner < "$ZSH_HISTORY" 2>/dev/null || true

    if [[ ! -s "$REPORT" ]] || [[ "$(jq 'length' "$REPORT" 2>/dev/null)" == "0" ]]; then
        log "zsh: no secrets found"
        return
    fi

    local count
    count=$(jq 'length' "$REPORT")
    log "zsh: found $count secret(s)"

    if [[ "$APPLY" == true ]]; then
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            local escaped
            escaped=$(printf '%s\n' "$secret" | sed 's/[&/\]/\\&/g')
            sed -i "/${escaped}/d" "$ZSH_HISTORY"
        done
        log "zsh: cleanup applied"
    else
        echo ""
        echo "# --- zsh: review and run these commands ---"
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            local escaped
            escaped=$(printf '%s\n' "$secret" | sed 's/[&/\]/\\&/g')
            echo "sed -i '/${escaped}/d' $ZSH_HISTORY"
        done
    fi

    : > "$REPORT"
}

scan_clipboard() {
    log "Scanning clipboard history ($CLIP_BACKEND)..."

    case "$CLIP_BACKEND" in
        gpaste)  _scan_gpaste ;;
        copyq)   _scan_copyq ;;
        *)       log "ERROR: unknown CLIP_BACKEND: $CLIP_BACKEND"; exit 1 ;;
    esac
}

_scan_gpaste() {
    if [[ ! -f "$GPASTE_HISTORY" ]]; then
        log "SKIP: gpaste history not found at $GPASTE_HISTORY"
        return
    fi

    gitleaks detect --pipe -r "$REPORT" --no-banner < "$GPASTE_HISTORY" 2>/dev/null || true

    if [[ ! -s "$REPORT" ]] || [[ "$(jq 'length' "$REPORT" 2>/dev/null)" == "0" ]]; then
        log "gpaste: no secrets found"
        return
    fi

    local count
    count=$(jq 'length' "$REPORT")
    log "gpaste: found $count secret(s)"

    if [[ "$APPLY" == true ]]; then
        if command -v gpaste-client &>/dev/null; then
            jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
                local escaped
                escaped=$(printf '%s\n' "$secret" | sed 's/[&/\]/\\&/g')
                gpaste-client history --raw 2>/dev/null \
                    | grep -n "$escaped" \
                    | cut -d: -f1 \
                    | sort -rn \
                    | while IFS= read -r idx; do
                        gpaste-client delete $((idx - 1)) 2>/dev/null || true
                    done
            done
            log "gpaste: cleanup applied"
        else
            log "gpaste: gpaste-client not found, removing secrets from XML directly"
            jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
                local escaped
                escaped=$(printf '%s\n' "$secret" | sed 's/[&/\]/\\&/g')
                sed -i "/${escaped}/d" "$GPASTE_HISTORY"
            done
            log "gpaste: cleanup applied (XML edited)"
        fi
    else
        echo ""
        echo "# --- gpaste: review and run these commands ---"
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            echo "# secret found in gpaste history — clear with:"
            echo "gpaste-client empty"
        done
    fi

    : > "$REPORT"
}

_scan_copyq() {
    if ! command -v copyq &>/dev/null; then
        log "SKIP: copyq not installed"
        return
    fi

    # dump all copyq rows into a temp file for scanning
    local dump
    dump=$(mktemp --suffix=.txt)
    trap 'rm -f "$dump"' RETURN

    local rows
    rows=$(copyq count 2>/dev/null || echo 0)
    for ((i = 0; i < rows; i++)); do
        copyq read "$i" 2>/dev/null
        echo
    done > "$dump"

    gitleaks detect --pipe -r "$REPORT" --no-banner < "$dump" 2>/dev/null || true

    if [[ ! -s "$REPORT" ]] || [[ "$(jq 'length' "$REPORT" 2>/dev/null)" == "0" ]]; then
        log "copyq: no secrets found"
        return
    fi

    local count
    count=$(jq 'length' "$REPORT")
    log "copyq: found $count secret(s)"

    if [[ "$APPLY" == true ]]; then
        # remove matching rows in reverse order to avoid index shift
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            for ((i = rows - 1; i >= 0; i--)); do
                local item
                item=$(copyq read "$i" 2>/dev/null)
                if [[ "$item" == *"$secret"* ]]; then
                    copyq remove "$i" 2>/dev/null || true
                fi
            done
        done
        log "copyq: cleanup applied"
    else
        echo ""
        echo "# --- copyq: review and run these commands ---"
        jq -r '.[].Secret' "$REPORT" | sort -u | while IFS= read -r secret; do
            echo "# secret found in copyq history — clear with:"
            echo "copyq remove <index>"
        done
    fi

    : > "$REPORT"
}

usage() {
    echo "Usage: $(basename "$0") [atuin|zsh|clipboard|all] [--apply]"
    echo ""
    echo "  atuin       scan atuin history only"
    echo "  zsh         scan zsh history only"
    echo "  clipboard   scan clipboard history only (CLIP_BACKEND: $CLIP_BACKEND)"
    echo "  all         scan all (default)"
    echo "  --apply     delete secrets instead of printing commands"
    exit 0
}

main() {
    local target="all"
    APPLY=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            atuin)     target="atuin";     shift ;;
            zsh)       target="zsh";       shift ;;
            clipboard) target="clipboard"; shift ;;
            all)       target="all";       shift ;;
            --apply) APPLY=true;    shift ;;
            -h|--help) usage ;;
            *) log "ERROR: unknown argument: $1"; usage ;;
        esac
    done

    check_deps

    case "$target" in
        atuin)     scan_atuin ;;
        zsh)       scan_zsh ;;
        clipboard) scan_clipboard ;;
        all)       scan_atuin; scan_zsh; scan_clipboard ;;
    esac

    log "Done"
}

main "$@"
