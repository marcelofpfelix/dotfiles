# this file will be included to zshrc and bashrc

################################################################################
# alias
################################################################################

# Git aliases
alias g='git'
alias gw='git worktree'
alias ga='git add'
alias gaa='git add .'
alias gs='git status'
alias gc='git commit'
alias gcam='git commit -am'
alias gl='git log --graph --pretty=format:"%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset" --abbrev-commit'

alias ssh='LC_USER=marcelof ssh'

# tool replacements
alias vi="nvim"
alias cat="bat -pP"
alias bathelp='bat -p --language=help'
alias batlog='cat -l log'
alias cdi="__zoxide_zi"

alias k="kubectl"
alias d="docker"

alias gpast="gpaste-client"
alias gopass="$HOME/bin/gopass-audit"
alias passs="gopass"

alias venv="source .env/bin/activate"
alias m="make"
alias ap="ansible-playbook"

alias sshhosts="sed -rn 's/^\s*Host\s+(.*)\s*/\1/ip' ~/.ssh/config ~/.ssh/config.d/work"



################################################################################
# export
################################################################################

# default editor
export EDITOR=/usr/bin/nvim

# bat settings
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# app exports
################################################################################

# allow vagrant experimental features
export VAGRANT_EXPERIMENTAL="1"
# pyenv
export PYENV_ROOT="$HOME/.pyenv"
# wireshark theme
export QT_STYLE_OVERRIDE=Adwaita-Dark
# Ruby Gems
export GEM_HOME="$HOME/gems"
# nvm
export NVM_DIR="$HOME/.nvm"
# fzf
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"


# path exports
################################################################################

# golang
export PATH=$PATH:/usr/local/go/bin
export PATH="$PATH:$HOME/go/bin"
# Ruby Gems
export PATH="$PATH:$HOME/gems/bin"
# pyenv
export PATH="$PATH:$PYENV_ROOT/bin"
# cargo
. "$HOME/.cargo/env"
# Add RVM to PATH for scripting. Make sure this is the last PATH variable change
export PATH="$PATH:$HOME/.rvm/bin"

# gpg
export GPG_TTY=$(tty)

# clipboard backend: gpaste or copyq
export CLIP_BACKEND="gpaste"

# gopass clipboard integration (hide secrets from clipboard manager history)
export GOPASS_CLIPBOARD_COPY_CMD="$HOME/bin/gopass-clip-copy"
export GOPASS_CLIPBOARD_CLEAR_CMD="$HOME/bin/gopass-clip-clear"
# https://github.com/gopasspw/gopass/blob/master/docs/usecases/gpaste.md


# ##############################################################################
