# Mirrors desktop/.wezterm.lua where Ghostty has equivalent settings.
theme = Catppuccin Mocha
font-family = Fira Code
font-size = 10

# WezTerm: window_background_opacity = 1.0
background-opacity = 1

# WezTerm: enable_tab_bar = false
window-show-tab-bar = never

# WezTerm: window_decorations = RESIZE
window-decoration = false
gtk-titlebar = false

# Copy/paste and OSC 52.
clipboard-read = ask
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
copy-on-select = clipboard

# Keep remote SSH sessions usable with Ghostty terminfo and environment.
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo,path
term = xterm-ghostty

confirm-close-surface = true
scrollback-limit = 100000000
mouse-hide-while-typing = true
cursor-style = block
cursor-style-blink = false

# WezTerm keys.
keybind = ctrl+f=toggle_fullscreen
keybind = shift+insert=paste_from_clipboard
